{# Compute shader — generated from OHAO engine template #}
#version 450

// {{ description }}

layout(local_size_x = 8, local_size_y = 8, local_size_z = 1) in;

{% for b in bindings %}
layout(set = 0, binding = {{ loop.index0 }}{% if b.type == 'image' %}, rgba16f{% endif %}) uniform {% if b.type == 'image' %}image2D{% elif b.type == 'sampler' %}sampler2D{% else %}buffer{% endif %} {{ b.name }};
{% endfor %}

layout(push_constant) uniform PushConstants {
    {% for pc in push_constants %}
    {{ pc.type }} {{ pc.name }};
    {% endfor %}
    {% if not push_constants %}
    float time;
    float deltaTime;
    uint width;
    uint height;
    {% endif %}
} pc;

void main() {
    ivec2 pixel = ivec2(gl_GlobalInvocationID.xy);
    {% if not push_constants %}
    if (pixel.x >= int(pc.width) || pixel.y >= int(pc.height)) return;

    vec2 uv = (vec2(pixel) + 0.5) / vec2(pc.width, pc.height);
    {% else %}
    ivec2 size = imageSize(output);
    if (pixel.x >= size.x || pixel.y >= size.y) return;

    vec2 uv = (vec2(pixel) + 0.5) / vec2(size);
    {% endif %}

    // TODO: Implement {{ name }} effect
    vec4 result = vec4(uv, 0.0, 1.0);

    imageStore(output, pixel, result);
}
