#version 460
#extension GL_EXT_ray_tracing : require

// Any-Hit Shader — ray hit geometry = pixel is shadowed
// For opaque shadows, this shader terminates the ray immediately.

layout(location = 0) rayPayloadInEXT float shadowPayload;

void main() {
    shadowPayload = 0.0;  // occluded = shadowed
    terminateRayEXT;
}
