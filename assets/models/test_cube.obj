# Test Cube Model
# Created for OHAO Engine testing
# Simple cube with 6 faces, each with different materials

mtllib test_cube.mtl

# Vertices (8 corners of a cube)
v -1.0 -1.0 -1.0
v  1.0 -1.0 -1.0
v  1.0  1.0 -1.0
v -1.0  1.0 -1.0
v -1.0 -1.0  1.0
v  1.0 -1.0  1.0
v  1.0  1.0  1.0
v -1.0  1.0  1.0

# Texture coordinates
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0

# Normals
vn  0.0  0.0 -1.0  # Back face
vn  0.0  0.0  1.0  # Front face
vn -1.0  0.0  0.0  # Left face
vn  1.0  0.0  0.0  # Right face
vn  0.0 -1.0  0.0  # Bottom face
vn  0.0  1.0  0.0  # Top face

# Back face (red material)
usemtl red_material
f 1/1/1 2/2/1 3/3/1 4/4/1

# Front face (green material)
usemtl green_material
f 5/1/2 8/2/2 7/3/2 6/4/2

# Left face (blue material)
usemtl blue_material
f 1/1/3 4/2/3 8/3/3 5/4/3

# Right face (yellow material)
usemtl yellow_material
f 2/1/4 6/2/4 7/3/4 3/4/4

# Bottom face (purple material)
usemtl purple_material
f 1/1/5 5/2/5 6/3/5 2/4/5

# Top face (cyan material)
usemtl cyan_material
f 4/1/6 3/2/6 7/3/6 8/4/6