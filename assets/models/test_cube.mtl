# Material Library for test_cube.obj
# Created for OHAO Engine testing

# Red material for back face
newmtl red_material
Ka 0.2 0.0 0.0  # Ambient: dark red
Kd 0.9 0.1 0.1  # Diffuse: bright red
Ks 0.5 0.5 0.5  # Specular: white highlights
Ns 32.0         # Shininess
d 1.0           # Dissolve (opacity)
illum 2         # Illumination model

